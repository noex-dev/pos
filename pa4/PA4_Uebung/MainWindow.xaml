<Window x:Class="PA4_Uebung.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PA4_Uebung"
        mc:Ignorable="d"
        Title="4. praktische Arbeit Übung" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Row="0" Click="Button_Click">Run</Button>
        <TextBox x:Name="Code" Grid.Row="1" AcceptsReturn="True"></TextBox>
        

        <Image Grid.Row="2" Grid.Column="2">
            <Image.Source>
                <BitmapImage UriSource="Europe.jpg"></BitmapImage>
            </Image.Source>
        </Image>
    </Grid>
</Window>
